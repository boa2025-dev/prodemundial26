# ── Notificaciones por email (api/cron/notify.ts) ──
# Configurar estas variables en Vercel → Project Settings → Environment Variables.
# No son necesarias para correr el frontend (npm run dev).

# JSON completo de la cuenta de servicio de Firebase (Firebase Console →
# Project Settings → Cuentas de servicio → Generar nueva clave privada).
# Pegar el JSON completo en una sola línea.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"...", ...}

# API key de Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Remitente verificado en Resend
RESEND_FROM_EMAIL=Prode Mundial 2026 <notificaciones@prodemundial26.online>

# Secreto random para proteger el endpoint de cron. Vercel lo envía
# automáticamente como header "Authorization: Bearer <CRON_SECRET>"
# en las ejecuciones programadas.
CRON_SECRET=un-secreto-aleatorio-largo
